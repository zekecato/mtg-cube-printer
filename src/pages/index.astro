---
// MTG Cube Printer — main page
// Server-side: nothing needed, all logic runs in the browser
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MTG Cube Printer</title>

  <style>
    /* ===== RESET ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ===== BASE ===== */
    body {
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      background: #e8ecf0;
      color: #1a1a2e;
      min-height: 100vh;
    }

    /* ===== HEADER ===== */
    .header {
      background: #1a1a2e;
      color: #fff;
      padding: 1.25rem 2rem;
      text-align: center;
    }
    .header h1 { font-size: 1.6rem; letter-spacing: -0.02em; }
    .header p  { font-size: 0.85rem; opacity: 0.65; margin-top: 0.15rem; }

    /* ===== CONTROLS BAR ===== */
    .controls {
      display: flex;
      flex-wrap: wrap;
      align-items: end;
      gap: 0.75rem;
      padding: 1rem 2rem;
      background: #fff;
      border-bottom: 1px solid #d0d5dd;
    }
    .ctrl-group {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .ctrl-group label {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #6b7280;
    }
    .ctrl-group input,
    .ctrl-group select {
      padding: 0.5rem 0.6rem;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      font-size: 0.875rem;
      background: #fff;
      outline: none;
      transition: border-color 0.15s;
    }
    .ctrl-group input:focus,
    .ctrl-group select:focus {
      border-color: #1a1a2e;
      box-shadow: 0 0 0 3px rgb(26 26 46 / 0.1);
    }
    .ctrl-group input[type="number"] { width: 75px; }

    .btn {
      padding: 0.5rem 1.4rem;
      border: none;
      border-radius: 6px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s, opacity 0.15s;
    }
    .btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .btn-primary { background: #1a1a2e; color: #fff; }
    .btn-primary:hover:not(:disabled) { background: #2d2d4a; }
    .btn-print   { background: #166534; color: #fff; font-size: 1rem; padding: 0.7rem 2rem; }
    .btn-print:hover:not(:disabled) { background: #15803d; }

    /* ===== INFO BAR ===== */
    .info-bar {
      padding: 0.7rem 2rem;
      font-size: 0.875rem;
      background: #f0fdf4;
      border-bottom: 1px solid #bbf7d0;
      color: #166534;
      display: none;
    }
    .info-bar.visible { display: block; }
    .info-bar.error   { background: #fef2f2; border-color: #fecaca; color: #991b1b; }

    /* ===== ACTIONS BAR ===== */
    .actions-bar {
      padding: 0.75rem 2rem;
      background: #fff;
      border-bottom: 1px solid #d0d5dd;
      display: none;
      align-items: center;
      gap: 1rem;
    }
    .actions-bar.visible { display: flex; }
    .page-summary { font-size: 0.85rem; color: #6b7280; }

    /* ===== SPINNER ===== */
    .spinner {
      display: none;
      width: 22px; height: 22px;
      border: 3px solid #d0d5dd;
      border-top-color: #1a1a2e;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      align-self: end;
      margin-bottom: 2px;
    }
    .spinner.visible { display: inline-block; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ===== PREVIEW AREA ===== */
    .preview {
      padding: 2rem;
      display: flex;
      justify-content: center;
    }
    .pages-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
      transform-origin: top center;
    }

    /* ===== PAGE ===== */
    .page {
      background: #fff;
      box-shadow: 0 2px 16px rgb(0 0 0 / 0.12);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 12.5mm;
      position: relative;
    }
    .page-num {
      position: absolute;
      bottom: 3mm;
      right: 5mm;
      font-size: 7pt;
      color: #9ca3af;
    }

    /* ===== CARDS GRID ===== */
    .cards-grid {
      display: grid;
    }
    .card {
      overflow: hidden;
      border-radius: 4.75% / 3.4%;
      background: #d1d5db;
      box-shadow: 0 1px 3px rgb(0 0 0 / 0.15);
    }
    .card img {
      display: block;
      width: 100%;
      height: 100%;
    }
    .card-placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 7pt;
      color: #9ca3af;
      user-select: none;
    }

    /* ===== PRINT OVERRIDES ===== */
    @media print {
      body              { background: #fff; }
      .header,
      .controls,
      .actions-bar,
      .info-bar         { display: none !important; }
      .preview          { padding: 0; }
      .pages-wrapper    { transform: none !important; gap: 0; }
      .page {
        box-shadow: none;
        break-after: page;
        page-break-after: always;
        margin: 0;
        padding: 0 !important;             /* @page margin handles whitespace */
        width: 100% !important;
        height: auto !important;
      }
      .page:last-child  { break-after: auto; page-break-after: auto; }
    }
  </style>

  <!-- Dynamic @page rules injected by JS -->
  <style id="print-page-css" media="print"></style>
</head>

<body>
  <header class="header">
    <h1>&#x1F0CF; MTG Cube Printer</h1>
    <p>Load a Cube Cobra cube &amp; print proxy sheets</p>
  </header>

  <!-- CONTROLS -->
  <div class="controls" id="controls">
    <div class="ctrl-group" style="flex:1; min-width:240px;">
      <label for="cubeUrl">Cube Cobra URL</label>
      <input type="text" id="cubeUrl"
             placeholder="https://cubecobra.com/cube/list/your-cube" />
    </div>
    <div class="ctrl-group">
      <label for="paperSize">Paper size</label>
      <select id="paperSize">
        <option value="letter">Letter (8.5×11″)</option>
        <option value="legal">Legal (8.5×14″)</option>
        <option value="a4" selected>A4</option>
        <option value="a3">A3</option>
      </select>
    </div>
    <div class="ctrl-group">
      <label for="gapMm">Gap (mm)</label>
      <input type="number" id="gapMm" value="2" min="0" max="20" step="0.5" />
    </div>
    <button class="btn btn-primary" id="btnLoad">Load Cube</button>
    <div class="spinner" id="spinner"></div>
  </div>

  <!-- INFO / ERROR MESSAGE -->
  <div class="info-bar" id="infoBar"></div>

  <!-- ACTIONS (shows after successful load) -->
  <div class="actions-bar" id="actionsBar">
    <button class="btn btn-print" id="btnPrint">🖨️ Print all pages</button>
    <span class="page-summary" id="pageSummary"></span>
  </div>

  <!-- PAGE PREVIEWS -->
  <div class="preview" id="preview">
    <div class="pages-wrapper" id="pagesWrapper"></div>
  </div>

  <script>
    // ================================================================
    //  CONSTANTS
    // ================================================================
    const CARD_W = 63;   // mm — standard Magic card width
    const CARD_H = 88;   // mm — standard Magic card height
    const MARGIN = 12.5; // mm — 1.25 cm margin on every side

    const PAPER = {
      letter: { w: 215.9, h: 279.4, label: 'letter' },
      legal:  { w: 215.9, h: 355.6, label: 'legal'  },
      a4:     { w: 210,   h: 297,   label: 'A4'     },
      a3:     { w: 297,   h: 420,   label: 'A3'     },
    };

    // ================================================================
    //  DOM REFS
    // ================================================================
    const $   = (id) => document.getElementById(id);
    const elCubeUrl     = $('cubeUrl');
    const elPaperSize   = $('paperSize');
    const elGapMm       = $('gapMm');
    const elBtnLoad     = $('btnLoad');
    const elSpinner     = $('spinner');
    const elInfoBar     = $('infoBar');
    const elActionsBar  = $('actionsBar');
    const elPageSummary = $('pageSummary');
    const elPagesWrap   = $('pagesWrapper');
    const elBtnPrint    = $('btnPrint');
    const elPrintCss    = $('print-page-css');

    // ================================================================
    //  STATE
    // ================================================================
    let cardImages = []; // list of image URLs

    // ================================================================
    //  HELPERS
    // ================================================================

    /** Pull the cube id from a Cube Cobra URL (or plain id string). */
    function extractCubeId(raw) {
      const s = raw.trim();
      try {
        const u = new URL(s);
        const parts = u.pathname.split('/').filter(Boolean);
        const idx = parts.findIndex(p =>
          ['overview', 'list', 'playtest', 'cube', 'blog'].includes(p)
        );
        return idx >= 0 && idx + 1 < parts.length ? parts[idx + 1] : parts[parts.length - 1] || '';
      } catch {
        return s; // treated as a raw cube id
      }
    }

    /** Try to get an image URL from a card object (Cube Cobra JSON shape).
     *  Mainboard cards have imgUrl at top level; basics have details.image_normal. */
    function getImageUrl(card) {
      // Direct imgUrl (mainboard)
      if (card.imgUrl) return card.imgUrl;
      // Nested details (basics / older format)
      const d = card.details || card;
      return d.image_normal || d.image_small || d.image_url ||
        (d.image_uris && d.image_uris.normal) || null;
    }

    /** How many cards fit on one page for given paper + gap. */
    function layout(paperW, paperH, gap) {
      const usableW = paperW - 2 * MARGIN;
      const usableH = paperH - 2 * MARGIN;
      const across = Math.max(1, Math.floor((usableW + gap) / (CARD_W + gap)));
      const down   = Math.max(1, Math.floor((usableH + gap) / (CARD_H + gap)));
      return { across, down, perPage: across * down };
    }

    // ---- UI helpers ----
    function setLoading(on) {
      elBtnLoad.disabled = on;
      elSpinner.className = 'spinner' + (on ? ' visible' : '');
      if (on) { elInfoBar.className = 'info-bar'; elActionsBar.className = 'actions-bar'; elPagesWrap.innerHTML = ''; }
    }
    function showMsg(text, isError = false) {
      elInfoBar.textContent = (isError ? '❌ ' : '') + text;
      elInfoBar.className = 'info-bar visible' + (isError ? ' error' : '');
    }

    /** Write the @page rule so the browser picks the right paper size on print. */
    function updatePrintCss(key) {
      const p = PAPER[key];
      elPrintCss.textContent = `@page { size: ${p.w}mm ${p.h}mm; margin: ${MARGIN}mm; }`;
    }

    // ================================================================
    //  LOAD CUBE (API call)
    // ================================================================
    async function loadCube() {
      const raw = elCubeUrl.value.trim();
      if (!raw) return showMsg('Paste a Cube Cobra URL first.', true);

      const cubeId = extractCubeId(raw);
      if (!cubeId) return showMsg('Could not find a cube id in that URL.', true);

      setLoading(true);
      showMsg('Loading cube “' + cubeId + '” …');

      try {
        // 1) Try fetching directly from Cube Cobra (fully client-side)
        const directUrl = 'https://cubecobra.com/cube/api/cubeJSON/' + cubeId;
        let resp;
        try {
          resp = await fetch(directUrl);
          if (resp.status === 0) throw new Error('CORS blocked');
        } catch {
          // Direct fetch blocked (CORS / network) — fall back to our proxy
          resp = await fetch('/api/cube?id=' + encodeURIComponent(cubeId));
        }

        if (!resp.ok) {
          const e = await resp.json().catch(() => ({}));
          throw new Error(e.error || 'HTTP ' + resp.status);
        }

        const data = await resp.json();
        // Cube Cobra returns cards grouped by board: { mainboard: [...], maybeboard: [...], basics: [...] }
        const boards = data.cards;
        if (!boards || typeof boards !== 'object') {
          throw new Error('Unexpected API response (no cards object).');
        }

        // Flatten all boards into one list (mainboard first, then maybeboard, then basics)
        const allCards = [];
        for (const key of ['mainboard', 'maybeboard', 'basics']) {
          if (Array.isArray(boards[key])) allCards.push(...boards[key]);
        }
        // Also accept a plain array as fallback
        if (allCards.length === 0 && Array.isArray(boards)) allCards.push(...boards);

        cardImages = allCards.map(getImageUrl).filter(Boolean);

        if (cardImages.length === 0) {
          showMsg('Cube loaded, but no cards have image URLs.', true);
          return;
        }

        renderPages();
        showMsg('✅ Loaded ' + cardImages.length + ' cards from “' + cubeId + '”.');
        elActionsBar.className = 'actions-bar visible';
      } catch (err) {
        showMsg(err.message || 'Unknown error', true);
        console.error(err);
      } finally {
        setLoading(false);
      }
    }

    // ================================================================
    //  RENDER PAGES
    // ================================================================
    function renderPages() {
      const paperKey = elPaperSize.value;
      const paper = PAPER[paperKey];
      const gap = parseFloat(elGapMm.value) || 0;

      const { across, down, perPage } = layout(paper.w, paper.h, gap);
      const totalPages = Math.ceil(cardImages.length / perPage);

      updatePrintCss(paperKey);

      // -- Choose a screen-preview scale so pages are roughly 380 px wide --
      const targetPx = Math.min(380, window.innerWidth - 80);
      const pxPerMm =  96 / 25.4;            // CSS px per mm at 96 dpi
      const scale  = targetPx / (paper.w * pxPerMm);

      elPagesWrap.innerHTML = '';
      elPagesWrap.style.transform = 'scale(' + scale + ')';

      // Compensate vertical space the scale transform doesn't reclaim
      const rawPageHeightPx = paper.h * pxPerMm + 32; // 32 px ≈ gap between pages in wrapper
      const scaledGapPx = 32 * scale;
      const compH = (1 - scale) * rawPageHeightPx * totalPages;
      elPagesWrap.style.marginBottom = -compH + 'px';

      let idx = 0;

      for (let p = 0; p < totalPages; p++) {
        const pageDiv = document.createElement('div');
        pageDiv.className = 'page';
        pageDiv.style.width  = paper.w + 'mm';
        pageDiv.style.height = paper.h + 'mm';

        const grid = document.createElement('div');
        grid.className = 'cards-grid';
        grid.style.gridTemplateColumns = 'repeat(' + across + ', ' + CARD_W + 'mm)';
        grid.style.gridTemplateRows    = 'repeat(' + down   + ', ' + CARD_H + 'mm)';
        grid.style.gap = gap + 'mm';

        for (let i = 0; i < perPage && idx < cardImages.length; i++, idx++) {
          const card = document.createElement('div');
          card.className = 'card';
          const img = document.createElement('img');
          img.src = cardImages[idx];
          img.alt = 'Card ' + (idx + 1);
          img.loading = 'lazy';
          img.onerror = function () {
            this.remove();
            card.textContent = '?';
            card.classList.add('card-placeholder');
          };
          card.appendChild(img);
          grid.appendChild(card);
        }

        // Fill leftover slots with blank placeholders (keeps grid shape)
        while (grid.children.length < perPage) {
          const ph = document.createElement('div');
          ph.className = 'card card-placeholder';
          grid.appendChild(ph);
        }

        pageDiv.appendChild(grid);

        const num = document.createElement('span');
        num.className = 'page-num';
        num.textContent = 'p. ' + (p + 1) + ' / ' + totalPages;
        pageDiv.appendChild(num);

        elPagesWrap.appendChild(pageDiv);
      }

      elPageSummary.textContent =
        totalPages + ' page' + (totalPages !== 1 ? 's' : '') +
        '  ·  ' + across + '×' + down + ' cards/page' +
        '  ·  gap ' + gap + ' mm' +
        '  ·  margin ' + MARGIN + ' mm';

      elPagesWrap.parentElement.scrollIntoView({ behavior: 'smooth' });
    }

    // ================================================================
    //  EVENT WIRING
    // ================================================================
    elBtnLoad.addEventListener('click', loadCube);
    elCubeUrl.addEventListener('keydown', e => { if (e.key === 'Enter') loadCube(); });
    elBtnPrint.addEventListener('click', () => window.print());

    // Re-render on paper / gap change if cards are already loaded
    elPaperSize.addEventListener('change', () => { if (cardImages.length) renderPages(); });
    elGapMm.addEventListener('change', () => { if (cardImages.length) renderPages(); });

    // Recalculate preview scale on resize (debounced)
    let resizeT;
    window.addEventListener('resize', () => {
      clearTimeout(resizeT);
      resizeT = setTimeout(() => { if (cardImages.length) renderPages(); }, 250);
    });

    // Bootstrap initial @page rule
    updatePrintCss(elPaperSize.value);
  </script>
</body>
</html>
