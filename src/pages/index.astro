---
// MTG Cube Printer — main page
// Server-side: nothing needed, the Svelte component handles everything client-side
import CubePrinter from '../components/CubePrinter.svelte';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MTG Cube Printer</title>

  <style>
    /* ===== GLOBAL RESET ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ===== BODY ===== */
    body {
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      background: #e8ecf0;
      color: #1a1a2e;
      min-height: 100vh;
    }

    @media print {
      body { background: #fff; }
    }
  </style>

  <!-- @page rule injected by the Svelte component at runtime -->
</head>

<body>
  <main>
    <CubePrinter client:only="svelte" />
  </main>
</body>
</html>
